FROM alpine:3.21

ARG TARGETPLATFORM

RUN apk add --no-cache ca-certificates tzdata

COPY $TARGETPLATFORM/suprclaw /usr/local/bin/suprclaw
COPY $TARGETPLATFORM/suprclaw-launcher /usr/local/bin/suprclaw-launcher
COPY $TARGETPLATFORM/suprclaw-launcher-tui /usr/local/bin/suprclaw-launcher-tui

ENTRYPOINT ["suprclaw-launcher"]
CMD ["-public", "-no-browser"]
